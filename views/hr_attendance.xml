<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="hr_attendance_form_inherit" model="ir.ui.view">
            <field name="name">hr_attendance.form.inherit</field>
            <field name="model">hr.attendance</field>
            <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='employee_id']" position="attributes">
                    <attribute name="options">{'no_create': True}</attribute>
                </xpath>
                <xpath expr="//header" position="inside">
                    <button type="object" string="calc" name="calculate_test_button"/>
                </xpath>
                <xpath expr="//field[@name='check_out']" position="after">
                    <field name="slip_id"/>
                    <field name="first_attendance"/>
                    <field name="lateness_deducted"
                           invisible="first_attendance == False or lateness_policy != 'apply_lateness_rules'"/>
                    <field name="lateness_deducted_hours"
                           invisible="first_attendance == False or lateness_policy != 'apply_lateness_hourly_quarter'"/>
                    <field name="is_leave" readonly="1"/>
                    <field name="is_public_holiday" readonly="1"/>
                    <!--                    <field name="is_time_off" readonly="1"/>-->
                    <field name="absence" readonly="0"/>
                </xpath>
                <xpath expr="//field[@name='employee_id']" position="after">
                    <field name="department_id"/>
                    <field name="parent_department"/>
                </xpath>
                  <xpath expr="//field[@name='in_mode']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>
            </field>
        </record>

        <record id="hr_attendance_tree_inherit" model="ir.ui.view">
            <field name="name">hr_attendance.tree.inherit</field>
            <field name="model">hr.attendance</field>
            <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='check_out']" position="after">
                    <field name="first_attendance"/>
                    <field name="slip_id"/>
                    <field name="lateness_deducted"/>
                    <field name="lateness_deducted_hours" optional="hide"/>
                    <field name="is_leave"/>
                    <field name="is_public_holiday"/>
                    <!--                    <field name="is_time_off"/>-->
                    <field name="absence"/>
                </xpath>
                <xpath expr="//field[@name='employee_id']" position="after">
                    <field name="department_id"/>
                    <field name="parent_department"/>
                </xpath>
            </field>
        </record>
        <record id="hr_attendance_search_inherit" model="ir.ui.view">
            <field name="name">hr_attendance.search.inherit</field>
            <field name="model">hr.attendance</field>
            <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='employee']" position="after">
                    <field name="lateness_deducted"/>
                    <filter string="lateness deducted" name="lateness_deducted"
                            context="{'group_by': 'lateness_deducted'}"/>
                </xpath>
            </field>
        </record>

        <record id="hr_attendance_view_filter_inherit" model="ir.ui.view">
            <field name="name">hr.attendance.view.filter.inherit</field>
            <field name="model">hr.attendance</field>
            <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
            <field name="arch" type="xml">
                <filter name="errors" position="replace">
                    <filter string="Errors" name="errors"
                            domain="['&amp;', ('check_out', '=', False), ('check_in', '&lt;=', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                </filter>
            </field>
        </record>

        <record model="ir.actions.server" id="compute_test_action">
            <field name="name">Compute All</field>
            <field name="model_id" ref="attendance_rule_flamico.model_hr_attendance"/>
            <field name="binding_model_id" ref="attendance_rule_flamico.model_hr_attendance"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                result = records.calculate_test_button()
            </field>
        </record>


    </data>
</odoo>