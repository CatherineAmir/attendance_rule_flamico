<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="resource_calendar_form_inherit" model="ir.ui.view">
            <field name="name">resource.calendar.form.inherit</field>
            <field name="model">resource.calendar</field>
            <field name="inherit_id" ref="resource.resource_calendar_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='hours_per_day']" position="after">
                    <label for="lateness_deducted_hourly_quarter"/>
                    <div>
                        <field name="lateness_deducted_hourly_quarter" style="width: 10%"/>
                        <span>Hours</span>
                    </div>
                    <label for="lateness_deducted_hourly_half"/>
                    <div>
                        <field name="lateness_deducted_hourly_half" style="width: 10%"/>
                        <span>Hours</span>
                    </div>
                    <label for="tolerance_deducted_minutes"/>
                    <div>
                        <field name="tolerance_deducted_minutes" style="width: 10%"/>
                        <span>Minutes</span>
                    </div>
                    <label for="tolerance_deducted_early_leave_minutes"/>
                    <div>
                        <field name="tolerance_deducted_early_leave_minutes" style="width: 10%"/>
                        <span>Minutes</span>
                    </div>

                    <xpath expr="//field[@name='hours_per_day']" position="attributes">
                        <attribute name="readonly">0</attribute>
                    </xpath>
                </xpath>
                <xpath expr="//field[@name='tz']" position="after">
                    <field name="is_day_shift_intersected" widget="boolean_toggle"/>
                </xpath>
                <xpath expr="//page[@name='working_hours']" position="after">
                    <page name="flexible_hours_holidays" string="Flexible Hours Holidays" invisible="not flexible_hours">
                        <group string="Holidays" invisible="not flexible_hours">
                            <field name="day_monday" widget="boolean_toggle"/>
                            <field name="day_tuesday" widget="boolean_toggle"/>
                            <field name="day_wednesday" widget="boolean_toggle"/>
                            <field name="day_thursday" widget="boolean_toggle"/>
                            <field name="day_friday" widget="boolean_toggle"/>
                            <field name="day_saturday" widget="boolean_toggle"/>
                            <field name="day_sunday" widget="boolean_toggle"/>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//form" position="inside">
                    <chatter/>
                </xpath>
            </field>
        </record>

        <record id="resource_calendar_list_inherit" model="ir.ui.view">
            <field name="name">resource.calendar.form.inherit</field>
            <field name="model">resource.calendar</field>
            <field name="inherit_id" ref="hr_contract.resource_calendar_view_tree"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='full_time_required_hours']" position="after">
                    <field name="is_day_shift_intersected"/>
                    <field name="hours_per_day"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>