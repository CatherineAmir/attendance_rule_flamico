<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_payslip_list_inherit" model="ir.ui.view">
            <field name="name">hr_payslip.list</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='employee_id']" position="after">
                    <field name="department_id"/>
                    <field name="parent_department"/>
                </xpath>
            </field>
        </record>

        <record id="hr_payslip_form_inherit" model="ir.ui.view">
            <field name="name">hr_payslip.form</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='struct_id']" position="after">
                    <field name="is_flexible_hours" invisible="1"/>
                </xpath>
                <xpath expr="//page[@name='salary_computation']" position="after">
                    <page name="attendance_rule" string="Attendance Rule" invisible="is_flexible_hours">
                        <group>
                            <group string="Lateness Deductions">

                                <field name="deducted_lateness_days" readonly="1"/>
                                <field name="deducted_lateness_amount" readonly="1"/>
                                <!--                                <field name="actual_deducted_lateness_amount"/>-->
                            </group>
                            <group string="Absence Deductions">
                                <field name="edit_manually" widget="boolean_toggle"/>
                                <field name="deducted_absence_days" readonly="not edit_manually"/>
                                <field name="deducted_absence_amount" readonly="1"/>
                                <!--                                <field name="actual_deducted_absence_amount" readonly="1"/>-->
                            </group>
                        </group>
                        <group>
                            <group string="Bonus Public Holiday">
                                <field name="number_of_public_holidays"/>
                                <field name="total_bonus_public_holiday"/>
                            </group>
                            <group string="overtime and Rewards">
                                <field name="total_attendance_days"/>
                                <field name="overtime_hours"/>
                                <field name="weekly_reward"/>
                            </group>
                        </group>
                        <group>
                            <group string="Early Leaving Deductions">
                                <field name="early_leave_hours" readonly="1"/>
                                <field name="early_leave_amount" readonly="1"/>
                                <!--                                <field name="actual_early_leave_amount"/>-->
                            </group>
                        </group>
                    </page>
                    <page name="flexible_hours" string="Attendance Rules Flexible Hours"
                          invisible="not is_flexible_hours">
                        <group string="Flexible Hours Rules">
                            <label for="flexible_hours_deducted_hours"/>
                            <div class="o_row mw-20" name="flexible_hours_deducted_hours">
                                <field name="flexible_hours_deducted_hours" class="oe_inline o_hr_narrow_field" nolabel="1" readonly="1"  widget="float_time"/>
                                <div class="mb-3" name="wage_period_label">Hours : Minutes</div>
                            </div>
                            <label for="flexible_hours_overtime_hours"/>
                            <div class="o_row mw-20" name="flexible_hours_overtime_hours">
                                <field name="flexible_hours_overtime_hours" class="oe_inline o_hr_narrow_field" nolabel="1" readonly="1" widget="float_time"/>
                                <div class="mb-3" name="wage_period_label">Hours : Minutes</div>
                            </div>
<!--                            <field name="flexible_hours_deducted_hours" readonly="1"/>-->
<!--                            <field name="flexible_hours_overtime_hours" readonly="1"/>-->
                            <label for="flexible_hours_deducted_days"/>
                            <div class="o_row mw-20" name="flexible_hours_deducted_days">
                                <field name="flexible_hours_deducted_days" class="oe_inline o_hr_narrow_field" nolabel="1" readonly="1"/>
                                <div class="mb-3" name="wage_period_label">Days</div>
                            </div>
<!--                            <field name="flexible_hours_deducted_days" readonly="1"/>-->
                        </group>

                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>